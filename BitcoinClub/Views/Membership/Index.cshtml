@model BitcoinClub.ViewModels.MembershipDashboardViewModel

@{
    ViewData["Title"] = "Membership";
}

<div class="membership-dashboard container mt-4">
    <h1 class="membership-page-title">Membership Dashboard</h1>

    <section class="membership-status-card card bg-dark text-light mb-4">
        <div class="membership-status-body card-body">
            <h5 class="membership-status-title card-title">Subscription Status</h5>
            <p class="membership-status-summary">
                <span class="membership-status-badge badge @(Model.IsActive ? "bg-success" : "bg-danger") fs-6">
                    @(Model.IsActive ? "Active" : "Expired")
                </span>
            </p>

            <dl class="membership-status-details row mb-0">
                <dt class="membership-status-label col-sm-4">Expiration Date</dt>
                <dd class="membership-status-value col-sm-8" id="subscription-expiration">@Model.ExpirationDate.ToString("dd MMM yyyy HH:mm UTC")</dd>

                <dt class="membership-status-label col-sm-4">Last Payment</dt>
                <dd class="membership-status-value col-sm-8" id="subscription-last-payment">
                    @(Model.LastPaymentDate.HasValue ? Model.LastPaymentDate.Value.ToString("dd MMM yyyy HH:mm UTC") : "—")
                </dd>

                <dt class="membership-status-label col-sm-4">Remaining Days</dt>
                <dd class="membership-status-value col-sm-8" id="subscription-remaining-days">@Model.RemainingDays</dd>
            </dl>
        </div>
    </section>

    <section class="membership-renewal-panel mb-4">
        <a asp-controller="Payments" asp-action="Initiate" class="membership-renewal-button btn btn-warning btn-lg">
            ⚡ Renew or support with Lightning
        </a>
    </section>

    <section class="membership-payment-history-section">
        <h2 class="membership-payment-history-title">Payment History</h2>
        @if (Model.PaymentHistory.Count == 0)
        {
            <p class="membership-payment-empty text-muted">No payments yet.</p>
        }
        else
        {
            <table class="membership-payment-history table table-dark table-striped" id="payment-history">
                <thead>
                    <tr>
                        <th>Created</th>
                        <th>Amount (sats)</th>
                        <th>Provider</th>
                        <th>Status</th>
                        <th>Paid At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.PaymentHistory)
                    {
                        <tr class="membership-payment-row">
                            <td class="membership-payment-created">@p.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                            <td class="membership-payment-amount">@p.AmountSats.ToString("N0")</td>
                            <td class="membership-payment-provider">@p.Provider</td>
                            <td class="membership-payment-status">
                                <span class="membership-payment-status-badge badge @(p.Status == "paid" ? "bg-success" : p.Status == "pending" ? "bg-warning" : "bg-secondary")">
                                    @p.Status
                                </span>
                            </td>
                            <td class="membership-payment-paid-at">@(p.PaidAt.HasValue ? p.PaidAt.Value.ToString("dd MMM yyyy HH:mm") : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>
