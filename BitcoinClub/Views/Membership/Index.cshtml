@model BitcoinClub.ViewModels.MembershipDashboardViewModel

@{
    ViewData["Title"] = "Membership";
}

<div class="container mt-4">
    <h1>Membership Dashboard</h1>

    <div class="card bg-dark text-light mb-4">
        <div class="card-body">
            <h5 class="card-title">Subscription Status</h5>
            <p>
                <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger") fs-6">
                    @(Model.IsActive ? "Active" : "Expired")
                </span>
            </p>

            <dl class="row mb-0">
                <dt class="col-sm-4">Expiration Date</dt>
                <dd class="col-sm-8" id="subscription-expiration">@Model.ExpirationDate.ToString("dd MMM yyyy HH:mm UTC")</dd>

                <dt class="col-sm-4">Last Payment</dt>
                <dd class="col-sm-8" id="subscription-last-payment">
                    @(Model.LastPaymentDate.HasValue ? Model.LastPaymentDate.Value.ToString("dd MMM yyyy HH:mm UTC") : "—")
                </dd>
            </dl>
        </div>
    </div>

    <div class="mb-4">
        <a asp-controller="Payments" asp-action="Initiate" class="btn btn-warning btn-lg">
            ⚡ Pay with Lightning
        </a>
    </div>

    <h2>Payment History</h2>
    @if (Model.PaymentHistory.Count == 0)
    {
        <p class="text-muted">No payments yet.</p>
    }
    else
    {
        <table class="table table-dark table-striped" id="payment-history">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Amount (sats)</th>
                    <th>Status</th>
                    <th>Paid At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.PaymentHistory)
                {
                    <tr>
                        <td>@p.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@p.AmountSats.ToString("N0")</td>
                        <td>
                            <span class="badge @(p.Status == "paid" ? "bg-success" : p.Status == "pending" ? "bg-warning" : "bg-secondary")">
                                @p.Status
                            </span>
                        </td>
                        <td>@(p.PaidAt.HasValue ? p.PaidAt.Value.ToString("dd MMM yyyy HH:mm") : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
