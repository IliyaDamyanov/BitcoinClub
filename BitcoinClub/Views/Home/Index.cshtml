@model BitcoinClub.ViewModels.LandingPageViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <div class="py-4">
        <h1 class="display-5">@Model.ClubName</h1>
        <p class="lead">@Model.Description</p>

        <hr />

        <h2>Mission</h2>
        <p>@Model.Mission</p>

        <h2>Events calendar</h2>
        <div class="ratio ratio-16x9">
            <iframe
                title="Bitcoin Club events"
                src="https://calendar.google.com/calendar/embed?mode=AGENDA"
                style="border:0"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>

        <h2>Contact</h2>
        <ul>
            <li>Email: <a href="mailto:@Model.ContactEmail">@Model.ContactEmail</a></li>
            @if (!string.IsNullOrWhiteSpace(Model.ContactTelegram))
            {
                <li>Telegram: @Model.ContactTelegram</li>
            }
        </ul>
    </div>
</div>
