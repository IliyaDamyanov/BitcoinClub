@page
@using BitcoinClub
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizerFactory LocalizerFactory

@model BitcoinClub.Areas.Identity.Pages.Account.LoginModel
@{
    var assemblyName = typeof(Program).Assembly.GetName().Name!;
    var L = LocalizerFactory.Create("Areas.Identity.Pages.Account.Login", assemblyName);
    ViewData["Title"] = L["Login_Title"];
    var currentLang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var toggleLang = string.Equals(currentLang, "en", System.StringComparison.OrdinalIgnoreCase) ? "BG" : "EN";
}

<div class="bc-auth-page">
    <div class="bc-auth-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="bc-auth-title">@L["Login_Title"]</h1>
                <p class="bc-auth-subtitle">@L["Login_Subtitle"]</p>
            </div>
            <div>
                <a class="btn btn-sm btn-outline-light bc-lang-button"
                   asp-action="SetLanguage"
                   asp-controller="Account"
                   asp-route-lang="@toggleLang"
                   asp-route-returnUrl="@Url.Page("/Account/Login", new { area = "Identity" })">
                    @toggleLang
                </a>
            </div>
        </div>

        <form method="post" class="bc-auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <input type="hidden" asp-for="ReturnUrl" />

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label bc-auth-label">@L["Login_EmailLabel"]</label>
                <input asp-for="Input.Email" class="form-control bc-auth-input" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label asp-for="Input.Password" class="form-label bc-auth-label mb-0">@L["Login_PasswordLabel"]</label>
                    <a asp-page="./ForgotPassword" class="bc-auth-forgot">@L["Login_ForgotPassword"]</a>
                </div>
                <input asp-for="Input.Password" class="form-control bc-auth-input" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input bc-auth-check" />
                    <label asp-for="Input.RememberMe" class="form-check-label bc-auth-check-label">@L["Login_RememberMe"]</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary bc-auth-button">@L["Login_Submit"]</button>

            <div class="mt-3 text-center">
                <a asp-area="" asp-controller="Account" asp-action="Register">@L["Login_RegisterLink"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
