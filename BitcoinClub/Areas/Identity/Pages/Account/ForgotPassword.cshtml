@page
@using BitcoinClub
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizerFactory LocalizerFactory

@model BitcoinClub.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    var assemblyName = typeof(Program).Assembly.GetName().Name!;
    var L = LocalizerFactory.Create("Areas.Identity.Pages.Account.ForgotPassword", assemblyName);
    ViewData["Title"] = L["ForgotPassword_Title"];
    var currentLang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var toggleLang = string.Equals(currentLang, "en", System.StringComparison.OrdinalIgnoreCase) ? "BG" : "EN";
}

<div class="bc-auth-page">
    <div class="bc-auth-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="bc-auth-title">@L["ForgotPassword_Title"]</h1>
                <p class="bc-auth-subtitle">@L["ForgotPassword_Subtitle"]</p>
            </div>
            <div>
                <a class="btn btn-sm btn-outline-light bc-lang-button"
                   asp-area=""
                   asp-action="SetLanguage"
                   asp-controller="Account"
                   asp-route-lang="@toggleLang"
                   asp-route-returnUrl="@Url.Page("/Account/ForgotPassword", new { area = "Identity" })">
                    @toggleLang
                </a>
            </div>
        </div>

        <form method="post" class="bc-auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="mb-4">
                <label asp-for="Input.Email" class="form-label bc-auth-label">@L["ForgotPassword_EmailLabel"]</label>
                <input asp-for="Input.Email" class="form-control bc-auth-input" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
                <div class="form-text bc-auth-hint mt-1">@L["ForgotPassword_Hint"]</div>
            </div>

            <button type="submit" class="btn btn-primary bc-auth-button">@L["ForgotPassword_Submit"]</button>

            <div class="mt-3 text-center">
                <a asp-page="./Login" class="bc-auth-back-link">
                    <i class="bi bi-arrow-left me-1"></i>@L["ForgotPassword_BackToLogin"]
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
